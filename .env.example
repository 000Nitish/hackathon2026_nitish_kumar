# ── Required ─────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here

# ── Model ────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash

# ── Concurrency (IMPORTANT: use 2 for free tier, 5+ for paid) ──
MAX_CONCURRENCY=2
TICKET_STAGGER_SECONDS=1.0

# ── Gemini API Retry (for rate limits) ────────────────────
GEMINI_MAX_RETRIES=4
GEMINI_RETRY_WAIT_MIN=15
GEMINI_RETRY_WAIT_MAX=120
GEMINI_REQUESTS_PER_MINUTE=5
GEMINI_RATE_WINDOW_SECONDS=60

# ── Agent Logic ───────────────────────────────────────────
MAX_REACT_ITERATIONS=10
CONFIDENCE_ESCALATION_THRESHOLD=0.60
REFUND_ESCALATION_AMOUNT=200.00

# ── Tools Retry ───────────────────────────────────────────
RETRY_MAX_ATTEMPTS=3
RETRY_WAIT_MIN=1
RETRY_WAIT_MAX=8

# ── Circuit Breaker ───────────────────────────────────────
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30

# ── Logging ───────────────────────────────────────────────
AGENT_LOG_LEVEL=INFO

# ── Testing (set to true for reproducible test failures) ──
DETERMINISTIC_FAILURES=false
